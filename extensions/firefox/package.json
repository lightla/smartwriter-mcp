{
  "name": "smartwriter-mcp-firefox",
  "version": "1.0.0",
  "description": "Smartwriter MCP Firefox Extension",
  "type": "module",
  "scripts": {
    "build": "bash build.sh",
    "watch": "tsup src/background.ts src/content.ts src/popup.ts --format iife --splitting false --target es2022 --outDir dist --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.4.0",
    "typescript": "^5.6.2"
  }
}
