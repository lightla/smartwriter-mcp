{
  "name": "smartwriter-mcp",
  "version": "1.0.0",
  "description": "Playwright-based MCP server for browser automation",
  "type": "module",
  "bin": {
    "smartwriter-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm && chmod +x dist/index.js",
    "watch": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@playwright/mcp": "^0.0.69",
    "playwright": "^1.59.0-alpha-1774912654000",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "typescript": "^5.6.2"
  }
}