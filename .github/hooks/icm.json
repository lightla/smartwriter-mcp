{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "/home/light/.local/bin/icm hook start",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "/home/light/.local/bin/icm hook pre",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "/home/light/.local/bin/icm hook post",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "/home/light/.local/bin/icm hook prompt",
        "timeoutSec": 10
      }
    ]
  }
}